# ── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────
# Local:  mongodb://localhost:27017/pams
# Atlas:  mongodb+srv://<username>:<password>@<cluster>.mongodb.net/pams
MONGO_URI=mongodb://localhost:27017/pams

# ── Authentication ───────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=30d

# ── Email (Gmail with App Password) ─────────────────────
EMAIL_USER=example@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── Default User Password ───────────────────────────────
DEFAULT_PASS=changeme

# ── Admin Seed Account ──────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=admin123
ADMIN_EMAIL=admin@example.com

# ── CORS / Client URL (required in production) ──────────
# Single origin:
CLIENT_URL=https://your-frontend.vercel.app
# Multiple origins (comma-separated):
# CLIENT_URLS=https://your-frontend.vercel.app,https://staging.vercel.app
